# BinnAgent Environment Configuration
# Copy this file to .env and adjust values for your setup.

# Database
BINN_DATABASE_URL=postgresql+asyncpg://binn:binn@localhost:5432/binn_agent

# Ollama (local LLM)
BINN_OLLAMA_BASE_URL=http://localhost:11434
BINN_OLLAMA_CHAT_MODEL=gemma4:e2b
BINN_OLLAMA_UTILITY_MODEL=gemma4:e2b
BINN_OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest

# Chat context and continuation
BINN_CHAT_MAX_TOKENS=2048
BINN_CHAT_HISTORY_LIMIT=12
BINN_CHAT_AUTO_CONTINUE_LIMIT=2

# Fallback provider (optional, disabled by default)
BINN_FALLBACK_ENABLED=false

# Redis
BINN_REDIS_URL=redis://localhost:6379/0

# Grade 7 knowledge-base PDF uploads
BINN_KNOWLEDGE_UPLOAD_DIR=var/knowledge/uploads
BINN_KNOWLEDGE_MAX_UPLOAD_BYTES=52428800
BINN_KNOWLEDGE_CHUNK_SIZE=900
BINN_KNOWLEDGE_CHUNK_OVERLAP=150
BINN_KNOWLEDGE_EMBEDDING_DIMENSIONS=768

# Langfuse observability (optional)
BINN_LANGFUSE_ENABLED=false
BINN_LANGFUSE_PUBLIC_KEY=
BINN_LANGFUSE_SECRET_KEY=
BINN_LANGFUSE_BASE_URL=http://localhost:3100
BINN_LANGFUSE_DOCKER_BASE_URL=http://host.docker.internal:3100
BINN_LANGFUSE_ENVIRONMENT=development

# Debug mode
BINN_DEBUG=false

# Dev Console (debug APIs remain disabled unless explicitly enabled)
BINN_DEBUG_CONSOLE_ENABLED=false
BINN_DEBUG_CONSOLE_TOKEN=
BINN_DEBUG_CONSOLE_ALLOWED_ORIGINS=["http://localhost:5174","http://127.0.0.1:5174"]
